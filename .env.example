# ScholarAgent Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env files with real keys to version control.

# --- Required (when using cloud backends) ---
OPENAI_API_KEY=           # OpenAI API key (for embeddings + OpenAI model routing)
ANTHROPIC_API_KEY=        # Anthropic API key (for strong/analytical agents)

# --- Optional ---
GITHUB_TOKEN=             # GitHub personal access token (for code search, higher rate limits)

# --- LLM Backend Configuration ---
# SCHOLAR_STRONG_BACKEND=anthropic     # "openai", "anthropic", or "lmstudio"
# SCHOLAR_STRONG_MODEL=claude-sonnet-4-6
# SCHOLAR_CHEAP_BACKEND=openai         # "openai", "anthropic", or "lmstudio"
# SCHOLAR_CHEAP_MODEL=gpt-4o-mini

# --- LM Studio (local models) ---
# SCHOLAR_LMSTUDIO_URL=http://localhost:1234/v1

# --- Embedding Configuration ---
# SCHOLAR_EMBEDDING_BACKEND=openai     # "openai" or "lmstudio"
# SCHOLAR_EMBEDDING_MODEL=text-embedding-3-small
# SCHOLAR_EMBEDDING_BASE_URL=
# SCHOLAR_EMBEDDING_API_KEY=

# --- Memory Storage ---
# SCHOLAR_MEMORY_DIR=~/.scholaragent
# SCHOLAR_MEMORY_DB=~/.scholaragent/memory.db
